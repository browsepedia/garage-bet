{
  "name": "garage-bet-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/garage-bet-app/src",
  "projectType": "application",
  "tags": [],
  "// targets": "to see all targets run: nx show project garage-bet-app --web",
  "targets": {
    "eas-build-ios": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eas build --platform ios",
        "cwd": "apps/garage-bet-app"
      }
    },
    "eas-build-android": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eas build --platform android",
        "cwd": "apps/garage-bet-app"
      }
    }
  }
}