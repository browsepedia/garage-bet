{
  "expo": {
    "name": "Garage Bet",
    "slug": "garage-bet",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "garage-bet-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.browsepedia.garagebet",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.browsepedia.garagebet"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "be63ac28-44ca-4873-8a1d-94ea6ccb2b28"
      },
      "router": {
        "root": "apps/garage-bet-app/app"
      }
    },
    "owner": "browsepedia"
  }
}
