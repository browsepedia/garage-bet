{
  "name": "garage-bet-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/garage-bet-api/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "prisma-generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "yarn prisma generate --schema=apps/garage-bet-api/prisma/schema.prisma"
      }
    },
    "prisma-migrate-dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "yarn prisma migrate dev --schema=apps/garage-bet-api/prisma/schema.prisma"
      }
    },
    "prisma-migrate-deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "yarn prisma migrate deploy --schema=apps/garage-bet-api/prisma/schema.prisma"
      }
    },
    "prisma-studio": {
      "executor": "nx:run-commands",
      "options": {
        "command": "yarn prisma studio --schema=apps/garage-bet-api/prisma/schema.prisma"
      }
    },
    "prisma-seed-world-cup-group-stage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node apps/garage-bet-api/prisma/seed-world-cup-group-stage.cjs"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack-cli build",
        "args": ["--node-env=production"],
        "cwd": "apps/garage-bet-api"
      },
      "configurations": {
        "development": {
          "args": ["--node-env=development"]
        }
      },
      "dependsOn": ["prisma-generate"]
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/dist/apps/garage-bet-api/package.json",
        "{workspaceRoot}/dist/apps/garage-bet-api/pnpm-lock.yaml"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": ["{workspaceRoot}/dist/apps/garage-bet-api/workspace_modules"],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "garage-bet-api:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "garage-bet-api:build:development"
        },
        "production": {
          "buildTarget": "garage-bet-api:build:production"
        }
      }
    },
    "test": {
      "options": {
        "passWithNoTests": true
      }
    }
  }
}
