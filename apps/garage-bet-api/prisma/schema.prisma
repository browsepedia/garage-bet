// apps/garage-bet-api/prisma/schema.prisma

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum MatchStatus {
    SCHEDULED
    LIVE
    FINISHED
    CANCELED
    POSTPONED
}

enum MatchStage {
    LEAGUE
    GROUP
    PLAY_OFF
    PLAY_OUT
    ROUND_OF_32
    ROUND_OF_16
    QUARTER_FINAL
    SEMI_FINAL
    THIRD_PLACE
    FINAL
}

enum AuthProvider {
    GOOGLE
    APPLE
    FACEBOOK
}

enum FriendshipStatus {
    PENDING
    ACCEPTED
    BLOCKED
}

model User {
    id           String  @id @default(cuid())
    email        String  @unique
    name         String?
    avatarUrl    String?
    passwordHash String?
    isAdmin      Boolean @default(false)

    /// Set when the user confirms their email (null until then for email/password sign-ups).
    emailVerifiedAt            DateTime?
    /// Opaque token for GET /auth/confirm-email; cleared after success or expiry.
    emailVerificationToken     String?   @unique
    emailVerificationExpiresAt DateTime?

    /// Opaque token for password reset link; cleared after use or expiry.
    passwordResetToken     String?   @unique
    passwordResetExpiresAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    accounts        AuthAccount[]
    refreshTokens   RefreshToken[]
    bets            Bet[]
    finalPlayerBets FinalPlayerBet[]
    devices         UserDevice[]

    friendshipsSent     Friendship[] @relation("friendshipsSent")
    friendshipsReceived Friendship[] @relation("friendshipsReceived")

    @@index([email])
}

/// Links a user to an app install id. The same deviceId may appear for multiple users.
model UserDevice {
    id                     String    @id @default(cuid())
    userId                 String
    deviceId               String
    /// Expo push token for this device (Expo Push API / FCM / APNs via Expo).
    expoPushToken          String?
    expoPushTokenUpdatedAt DateTime?
    createdAt              DateTime  @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, deviceId])
    @@index([userId])
    @@index([deviceId])
}

model AuthAccount {
    id                String       @id @default(cuid())
    userId            String
    provider          AuthProvider
    providerAccountId String

    accessToken  String?
    refreshToken String?
    expiresAt    DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
    @@index([userId])
}

model RefreshToken {
    id        String    @id @default(cuid())
    userId    String
    tokenHash String    @unique
    expiresAt DateTime
    revokedAt DateTime?

    userAgent String?
    ip        String?

    createdAt DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([expiresAt])
}

model Team {
    id        String  @id @default(cuid())
    name      String
    shortName String?
    logoUrl   String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    seasons SeasonTeam[]

    homeMatches Match[] @relation("homeTeam")
    awayMatches Match[] @relation("awayTeam")

    seasonFinalHomeFor Season[] @relation("SeasonFinalHome")
    seasonFinalAwayFor Season[] @relation("SeasonFinalAway")

    @@unique([name])
}

model Competition {
    id   String @id @default(cuid())
    name String
    slug String @unique

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    seasons Season[]
}

model Season {
    id            String @id @default(cuid())
    competitionId String
    name          String
    year          Int?

    /// Actual finalists + result (set by admin when known). Used to score FinalPlayerBet.
    finalHomeTeamId  String?
    finalAwayTeamId  String?
    finalHomeScore   Int?
    finalAwayScore   Int?
    finalBettingOpen Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

    finalHomeTeam Team? @relation("SeasonFinalHome", fields: [finalHomeTeamId], references: [id], onDelete: SetNull)
    finalAwayTeam Team? @relation("SeasonFinalAway", fields: [finalAwayTeamId], references: [id], onDelete: SetNull)

    teams           SeasonTeam[]
    matches         Match[]
    finalPlayerBets FinalPlayerBet[]

    @@unique([competitionId, name])
    @@index([competitionId])
}

model SeasonTeam {
    id       String @id @default(cuid())
    seasonId String
    teamId   String

    season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
    team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

    @@unique([seasonId, teamId])
    @@index([teamId])
}

model Match {
    id       String @id @default(cuid())
    seasonId String

    kickoffAt DateTime
    status    MatchStatus @default(SCHEDULED)

    stage     MatchStage @default(LEAGUE)
    groupName String?
    round     String?
    matchday  Int?

    homeTeamId String
    awayTeamId String

    homeScore Int?
    awayScore Int?

    /**
     * Stadium / city label for display (optional for non-seeded matches).
     */
    venue String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
    homeTeam Team   @relation("homeTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
    awayTeam Team   @relation("awayTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)

    bets Bet[]

    @@unique([seasonId, kickoffAt, homeTeamId, awayTeamId])
    @@index([seasonId, kickoffAt])
    @@index([homeTeamId])
    @@index([awayTeamId])
}

model Bet {
    id      String @id @default(cuid())
    matchId String
    userId  String

    homeScore Int
    awayScore Int

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
    user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([matchId, userId])
    @@index([userId])
    @@index([matchId])
}

/// One prediction per user per season (championship edition): finalists + score.
model FinalPlayerBet {
    id                  String @id @default(cuid())
    seasonId            String
    userId              String
    predictedHomeTeamId String
    predictedAwayTeamId String
    predictedHomeScore  Int
    predictedAwayScore  Int

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([seasonId, userId])
    @@index([seasonId])
    @@index([userId])
}

model Friendship {
    id          String           @id @default(cuid())
    requesterId String
    addresseeId String
    status      FriendshipStatus @default(PENDING)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    requester User @relation("friendshipsSent", fields: [requesterId], references: [id], onDelete: Cascade)
    addressee User @relation("friendshipsReceived", fields: [addresseeId], references: [id], onDelete: Cascade)

    @@unique([requesterId, addresseeId])
    @@index([requesterId])
    @@index([addresseeId])
}
